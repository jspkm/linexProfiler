{
    "functions": {
        "source": "backend",
        "codebase": "default",
        "ignore": [
            ".git",
            ".firebase",
            ".firebase/**",
            "node_modules",
            "node_modules/**",
            "venv",
            "venv/**",
            ".venv",
            ".venv/**",
            "*.log",
            "*-debug.log",
            "gunicorn.ctl",
            "__pycache__",
            "**/__pycache__/**",
            ".gemini",
            ".gemini/**",
            "*.pyc"
        ]
    },
    "hosting": {
        "target": "linexprofiler",
        "public": "web/out",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/api/analyze_transactions",
                "function": "analyze_transactions"
            },
            {
                "source": "/api/ask_qu",
                "function": "ask_qu"
            },
            {
                "source": "/api/list_test_users",
                "function": "list_test_users"
            },
            {
                "source": "/api/analyze_test_user",
                "function": "analyze_test_user"
            },
            {
                "source": "/api/ask_test_user",
                "function": "ask_test_user"
            }
        ]
    }
}