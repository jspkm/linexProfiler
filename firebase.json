{
    "functions": {
        "source": "backend",
        "codebase": "default",
        "ignore": [
            ".git",
            ".firebase",
            ".firebase/**",
            "node_modules",
            "node_modules/**",
            "venv",
            "venv/**",
            ".venv",
            ".venv/**",
            "*.log",
            "*-debug.log",
            "gunicorn.ctl",
            "__pycache__",
            "**/__pycache__/**",
            ".gemini",
            ".gemini/**",
            "*.pyc",
            "data",
            "data/**",
            "linexonewhitelabeler-firebase-adminsdk-*.json"
        ]
    },
    "hosting": {
        "target": "linex-terminal",
        "public": "web/out",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/api/analyze_transactions",
                "function": "analyze_transactions"
            },
            {
                "source": "/api/ask_agent",
                "function": "ask_agent"
            },
            {
                "source": "/api/agent_chat",
                "function": "agent_chat"
            },
            {
                "source": "/api/list_test_users",
                "function": "list_test_users"
            },
            {
                "source": "/api/analyze_test_user",
                "function": "analyze_test_user"
            },
            {
                "source": "/api/ask_test_user",
                "function": "ask_test_user"
            },
            {
                "source": "/api/learn_profiles",
                "function": "learn_profiles"
            },
            {
                "source": "/api/list_profile_catalogs",
                "function": "list_profile_catalogs"
            },
            {
                "source": "/api/list_portfolio_datasets",
                "function": "list_portfolio_datasets"
            },
            {
                "source": "/api/create_portfolio_upload_url",
                "function": "create_portfolio_upload_url"
            },
            {
                "source": "/api/profile_catalog",
                "function": "profile_catalog"
            },
            {
                "source": "/api/profile_catalog/**",
                "function": "profile_catalog"
            },
            {
                "source": "/api/fork_catalog",
                "function": "fork_catalog_fn"
            },
            {
                "source": "/api/delete_catalog/**",
                "function": "delete_catalog_fn"
            },
            {
                "source": "/api/delete_portfolio_dataset/**",
                "function": "delete_portfolio_dataset_fn"
            },
            {
                "source": "/api/start_optimize",
                "function": "start_optimize_fn"
            },
            {
                "source": "/api/optimize_status/**",
                "function": "optimize_status"
            },
            {
                "source": "/api/list_optimizations",
                "function": "list_optimizations_fn"
            },
            {
                "source": "/api/load_optimize/**",
                "function": "load_optimize_fn"
            },
            {
                "source": "/api/cancel_optimize/**",
                "function": "cancel_optimize_fn"
            },
            {
                "source": "/api/save_optimize/**",
                "function": "save_optimize_fn"
            },
            {
                "source": "/api/delete_optimize/**",
                "function": "delete_optimize_fn"
            },
            {
                "source": "/api/list_incentive_sets",
                "function": "list_incentive_sets"
            },
            {
                "source": "/api/incentive_set",
                "function": "incentive_set"
            },
            {
                "source": "/api/incentive_set/**",
                "function": "incentive_set"
            },
            {
                "source": "/api/create_incentive_set",
                "function": "create_incentive_set_fn"
            },
            {
                "source": "/api/set_default_incentive_set/**",
                "function": "set_default_incentive_set_fn"
            },
            {
                "source": "/api/delete_incentive_set/**",
                "function": "delete_incentive_set_fn"
            }
        ]
    }
}
