{
  "name": "linex-terminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -lc 'set -a; [ -f .env.dev ] && source .env.dev; [ -f .env.local ] && source .env.local; set +a; next dev'",
